# ============================================================
#  Copy this file to ".env" and fill in the values.
#    cp .env.example .env
# ============================================================

# Flask session signing key — set to any long random string.
SECRET_KEY=change-this-to-a-long-random-string

# Admin dashboard — only this email can access /admin
ADMIN_EMAIL=

# ------------------------------------------------------------
#  Free LLM provider for the "Ask a doubt" tutor.
#  Pick ONE provider and add its key. Default = gemini.
#    Options: gemini | groq | ollama
# ------------------------------------------------------------
LLM_PROVIDER=gemini

# Google Gemini — generous free tier.
# Get a free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq — free, very fast. https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ollama — fully local & free, no key needed. https://ollama.com
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
